# Copia este archivo a .env.local y rellena la clave para activar la capa de IA.
# Sin clave, el MVP funciona igual: muestra los puntajes exactos del motor HUMAN
# y las interpretaciones deterministas del manual. La IA (Evaluador UNO/DOS) es aditiva.

ANTHROPIC_API_KEY=

# Modelo de Claude para los evaluadores (opcional; default abajo).
ANTHROPIC_MODEL=claude-opus-4-8
